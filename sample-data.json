  "recipes": [
    {
      "name": "Scrambled Eggs",
      "servings": 1,
      "directions": "Crack eggs into a bowl and whisk until combined. Heat olive oil in a non-stick pan over medium-low heat. Pour in eggs and stir gently with a spatula, folding slowly until just set. Remove from heat while still slightly glossy. Season with salt and pepper.",
      "ingredients": [
        { "ingredientName": "Eggs",      "servingSize": { "amount": 3, "unit": "UNIT" } },
        { "ingredientName": "Olive Oil", "servingSize": { "amount": 1, "unit": "TEASPOON" } }
      ]
    },
    {
      "name": "Grilled Chicken & Rice Bowl",
      "servings": 2,
      "directions": "Cook brown rice according to package directions. Season chicken with salt, pepper, garlic powder, and paprika. Heat olive oil in a pan over medium-high heat and cook chicken 6-7 minutes per side until internal temp reaches 165F. Steam broccoli until tender-crisp, about 5 minutes. Slice chicken and serve over rice with broccoli.",
      "ingredients": [
        { "ingredientName": "Chicken Breast", "servingSize": { "amount": 400, "unit": "GRAM" } },
        { "ingredientName": "Brown Rice",     "servingSize": { "amount": 200, "unit": "GRAM" } },
        { "ingredientName": "Broccoli",       "servingSize": { "amount": 200, "unit": "GRAM" } },
        { "ingredientName": "Olive Oil",      "servingSize": { "amount": 1,   "unit": "TABLESPOON" } }
      ]
    },
    {
      "name": "Overnight Oats",
      "servings": 1,
      "directions": "Combine oats, milk, and Greek yogurt in a jar or bowl. Stir well to combine. Cover and refrigerate for at least 6 hours or overnight. Serve cold. Top with fruit or honey if desired.",
      "ingredients": [
        { "ingredientName": "Rolled Oats",  "servingSize": { "amount": 90,  "unit": "GRAM" } },
        { "ingredientName": "Whole Milk",   "servingSize": { "amount": 1,   "unit": "CUP" } },
        { "ingredientName": "Greek Yogurt", "servingSize": { "amount": 150, "unit": "GRAM" } }
      ]
    },
    {
      "name": "Black Bean & Rice Bowl",
      "servings": 2,
      "directions": "Cook brown rice. Drain and rinse black beans, then warm in a small saucepan over medium heat. Heat olive oil in a pan, add spinach and cook for 1-2 minutes until wilted. Season everything with cumin, salt, and lime juice. Serve beans and spinach over rice.",
      "ingredients": [
        { "ingredientName": "Black Beans", "servingSize": { "amount": 400, "unit": "GRAM" } },
        { "ingredientName": "Brown Rice",  "servingSize": { "amount": 150, "unit": "GRAM" } },
        { "ingredientName": "Spinach",     "servingSize": { "amount": 100, "unit": "GRAM" } },
        { "ingredientName": "Olive Oil",   "servingSize": { "amount": 1,   "unit": "TABLESPOON" } }
      ]
    },
    {
      "name": "Keto Salmon & Broccoli",
      "servings": 2,
      "directions": "Preheat oven to 400F. Toss broccoli florets in half the olive oil, season with salt and pepper, and spread on a baking sheet. Roast 20 minutes until edges are crispy. Pat salmon dry, season generously with salt, pepper, and garlic powder. Heat remaining oil in an oven-safe skillet over high heat. Sear salmon skin-side up for 3 minutes, flip, then transfer pan to oven for 8-10 minutes until salmon flakes easily.",
      "ingredients": [
        { "ingredientName": "Salmon",    "servingSize": { "amount": 400, "unit": "GRAM" } },
        { "ingredientName": "Broccoli",  "servingSize": { "amount": 300, "unit": "GRAM" } },
        { "ingredientName": "Olive Oil", "servingSize": { "amount": 2,   "unit": "TABLESPOON" } }
      ]
    },
    {
      "name": "Ground Beef Stir Fry",
      "servings": 2,
      "directions": "Heat olive oil in a wok or large skillet over high heat. Add ground beef and cook, breaking it apart, until browned and cooked through, about 7 minutes. Drain excess fat. Add broccoli and stir fry for 3-4 minutes until tender-crisp. Add spinach and toss for 1 minute until wilted. Season with soy sauce, garlic, and a pinch of red pepper flakes.",
      "ingredients": [
        { "ingredientName": "Ground Beef (80/20)", "servingSize": { "amount": 300, "unit": "GRAM" } },
        { "ingredientName": "Broccoli",            "servingSize": { "amount": 200, "unit": "GRAM" } },
        { "ingredientName": "Spinach",             "servingSize": { "amount": 80,  "unit": "GRAM" } },
        { "ingredientName": "Olive Oil",           "servingSize": { "amount": 1,   "unit": "TABLESPOON" } }
      ]
    },
    {
      "name": "Cheese & Egg Scramble",
      "servings": 1,
      "directions": "Heat olive oil in a non-stick pan over medium heat. Add spinach and cook for 1 minute until wilted. Whisk eggs and pour over the spinach. Stir gently as eggs cook. When nearly set, sprinkle cheddar cheese over the top and let it melt for 30 seconds. Fold and serve immediately.",
      "ingredients": [
        { "ingredientName": "Eggs",           "servingSize": { "amount": 3,  "unit": "UNIT" } },
        { "ingredientName": "Cheddar Cheese", "servingSize": { "amount": 30, "unit": "GRAM" } },
        { "ingredientName": "Spinach",        "servingSize": { "amount": 50, "unit": "GRAM" } },
        { "ingredientName": "Olive Oil",      "servingSize": { "amount": 1,  "unit": "TEASPOON" } }
      ]
    },
    {
      "name": "Sweet Potato & Chicken Bowl",
      "servings": 2,
      "directions": "Preheat oven to 425F. Cube sweet potatoes and toss with half the olive oil, salt, and pepper. Roast for 25-30 minutes until soft and caramelized. Meanwhile, season chicken with salt, pepper, and smoked paprika. Cook in remaining olive oil over medium-high heat, 6-7 minutes per side. Slice chicken and serve over roasted sweet potato with a handful of spinach.",
      "ingredients": [
        { "ingredientName": "Chicken Breast", "servingSize": { "amount": 350, "unit": "GRAM" } },
        { "ingredientName": "Sweet Potato",   "servingSize": { "amount": 400, "unit": "GRAM" } },
        { "ingredientName": "Spinach",        "servingSize": { "amount": 60,  "unit": "GRAM" } },
        { "ingredientName": "Olive Oil",      "servingSize": { "amount": 1,   "unit": "TABLESPOON" } }
      ]
    }
